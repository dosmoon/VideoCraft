# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
# ...but keep the hand-authored brand icon (electron-builder buildResources).
!desktop/build/
desktop/build/*
!desktop/build/icon.ico
!desktop/build/icon.png
# ...and the hand-authored NSIS customRemoveFiles include (preserves user_data
# across update; electron-builder auto-includes it from buildResources).
!desktop/build/installer.nsh
dist/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec
# ...but the VideoCraft sidecar spec is hand-authored and tracked (P3 packaging).
!packaging/core_rpc.spec

# P3 packaging build artifacts (produced by packaging/build_sidecar.ps1 +
# electron-builder; never committed — rebuilt from source).
.build/
desktop/resources/
desktop/release/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# celery beat schedule file
celerybeat-schedule

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
/env/
venv/
/ENV/
env.bak/
venv.bak/
myenv/

# But our source package src/core/env/ is NOT a virtualenv — track it.
!src/core/env/

# Local test artifacts at repo root (TTS output, etc.)
/output.mp3
/output.wav
/output.opus

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# Docs site (Astro/Starlight): site/ source is tracked; ignore build artifacts.
# site/src/content/docs/ is generated by site/scripts/sync-docs.mjs from docs/public/.
site/src/content/docs/
site/node_modules/
site/dist/
site/.astro/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# IDE
.vscode/
.idea/
.claude/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Database
*.db
*.sqlite
*.sqlite3

# Keys and sensitive files
keys/
DeepL.key
*.key

# User data (per-install state: settings, layout, recent projects, presets, autosave)
user_data/

# AI Console Playground fixtures (per-user test data; never commit — may contain real subtitles/transcripts)
prompts/_fixtures/


# WebView2 user data (Edge profile created during preview embed)
.webview_userdata/

# Local scratch / experiment artifacts (test outputs, payloads)
scratch/
